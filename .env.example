# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ── GLM-OCR (handwriting / scanned-PDF vision pipeline) ───────────────
# Default endpoint is the team's self-hosted vLLM (ocr.cyberkunju.com/v1).
# Swap to any OpenAI-compatible OCR provider by overriding these.
GLM_OCR_BASE_URL=https://ocr.cyberkunju.com/v1
GLM_OCR_API_KEY=sk-ocr-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GLM_OCR_MODEL=glm-ocr:q8_0

# ── OpenAI (chat agent) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Zoho Mail — real-email ingestion for tia@cyberkunju.com ──────────
# Generate an App Password at https://accounts.zoho.com/ → Security →
# App Passwords. Required if 2FA is enabled (recommended).
ZOHO_IMAP_USER=tia@cyberkunju.com
ZOHO_IMAP_PASSWORD=xxxxxxxxxxxx
ZOHO_IMAP_HOST=imap.zoho.com
ZOHO_IMAP_PORT=993
ZOHO_IMAP_FOLDER=INBOX
ZOHO_POLL_INTERVAL_SEC=30
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USE_SSL=1

# ── Mailbox webhook auth (Postmark/SES production pattern) ───────────
# When set, /intake/mailbox-webhook requires X-Webhook-Signature header
# = hex(hmac_sha256(secret, body)). Leave unset for dev.
MAILBOX_WEBHOOK_SECRET=

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///tia.db
# For Postgres 18: postgresql+psycopg://tia:tia@localhost:5432/tia

# ── Rust dispatch service (optional — Python falls back to in-process) ─
RUST_DISPATCH_URL=http://127.0.0.1:8001
