# ── Compose configuration — copy to .env and adjust ─────────────────────────
#   cp .env.docker.example .env
# .env is gitignored; never commit real secrets.

# Postgres credentials (the api builds its DATABASE_URL from these).
# POSTGRES_PASSWORD is REQUIRED — compose fails fast if it is unset, so a stale
# volume password can never silently drift out of sync with the app. Generate a
# strong value once and keep it stable for the life of the db-data volume:
#   openssl rand -hex 24
POSTGRES_USER=tia
POSTGRES_PASSWORD=change-me-use-openssl-rand-hex-24
POSTGRES_DB=tia

# Host port the SPA (nginx) is published on → http://localhost:${WEB_PORT}
# Bound to 127.0.0.1 by compose; the Cloudflare tunnel reaches it over loopback.
WEB_PORT=8090

# ── Resource limits (workers AUTO-SIZE to this budget; set to your box) ──────
# uvicorn workers are chosen at startup from the smaller of (CPU cores) and
# (API_MEM / ~300MB), so the api never OOMs or oversubscribes cores on ANY host.
# Memory is worker-count-driven: ~260MB base + ~170MB/worker resident.
# Set API_CPUS/API_MEM to your hardware; the worker count and concurrency follow.
#
#   box                 API_CPUS  API_MEM   => workers   5 concurrent users
#   1 CPU / 1 GB        1.0       1G            1         serialize, no failures
#   2 CPU / 2 GB        2.0       1280M         2         2 parallel, rest queue
#   4 CPU / 4 GB (here) 3.0       1536M         3         3 parallel, sub-second
#
# To force a fixed count regardless of the box, set UVICORN_WORKERS=<n>.
API_CPUS=3.0
API_MEM=1536M
API_MEM_MIN=512M
DB_CPUS=1.0
DB_MEM=512M

# API runtime — "auto" right-sizes workers to CPU+memory (recommended). Pin a
# number only if you want a fixed worker count regardless of the host.
UVICORN_WORKERS=auto
LOG_LEVEL=info
TIA_SEED_ON_START=true
TIA_SYNTH_ON_START=true
# Confidence-gated touchless path (the product default): clean + rule-passing +
# under-threshold timesheets auto-invoice; only low-confidence / ambiguous / rule-
# flagged ones go to the web approval queue. Set false to force approval on all.
TIA_AUTO_APPROVE=true

# GLM-OCR — OpenAI-compatible vision endpoint for the handwritten/PDF case.
# BASE_URL may include or omit the trailing /v1. Leave the key empty to disable OCR.
GLM_OCR_BASE_URL=https://ocr.cyberkunju.com/v1
GLM_OCR_API_KEY=
GLM_OCR_MODEL=glm-ocr:q8_0

# Context-aware /qa chat agent — Azure OpenAI (gpt-5.4-nano). No direct OpenAI key.
AZURE_AI_ENDPOINT=https://aip-f-resource.services.ai.azure.com
AZURE_AI_KEY=
AZURE_AI_API_VERSION=2024-05-01-preview
AZURE_CHAT_MODEL=gpt-5.4-nano

# ── Zoho Mail — email-intake mailbox (tia@cyberkunju.com) + outbound replies ──
ZOHO_IMAP_USER=
ZOHO_IMAP_PASSWORD=
ZOHO_IMAP_HOST=imap.zoho.in
ZOHO_IMAP_PORT=993
ZOHO_IMAP_FOLDER=INBOX
ZOHO_POLL_INTERVAL_SEC=10
ZOHO_SMTP_HOST=smtp.zoho.in
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USE_SSL=1

# ── WhatsApp bridge (optional; `docker compose --profile whatsapp up -d`) ───
# Required only when running the bridge. Get these from the Meta App dashboard.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=tia-verify-dev
WHATSAPP_API_VERSION=v23.0
WHATSAPP_PORT=8088
# Public URL of the bridge (used to build attachment_url the core fetches). In a
# single-host compose deployment behind a tunnel, set this to the bridge's public origin.
BRIDGE_PUBLIC_URL=http://whatsapp:8088
# Shared secret guarding the bridge's /internal/notify. The api service uses the same
# value to push approved invoices back to the WhatsApp sender. Keep them identical.
INTERNAL_SECRET=tia-internal-dev
