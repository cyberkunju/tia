[Unit]
Description=TIA continuous deploy (poll origin, redeploy on change)
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# docker lives in /usr/bin; the user-level compose plugin is found via $HOME/.docker.
Environment=PATH=/usr/local/bin:/usr/bin:/bin
# Invoke via bash so a missing +x bit (e.g. after a Windows-authored checkout) can't
# break the timer with status=203/EXEC.
ExecStart=/bin/bash %h/Deploy/tia/deploy/update.sh
TimeoutStartSec=1800
