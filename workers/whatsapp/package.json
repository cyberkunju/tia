{
  "name": "tia-whatsapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TIA WhatsApp bridge - Meta Cloud API adapter that forwards timesheets to the TIA core (Bun + Hono + TypeScript)",
  "module": "src/server.ts",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "simulate": "bun run src/simulate.ts",
    "ops": "bun run src/ops.ts"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  }
}
