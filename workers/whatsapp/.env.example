# ── Meta WhatsApp Cloud API ────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=tia-verify-dev
WHATSAPP_API_VERSION=v23.0

# ── TIA core (where the bridge forwards each message) ──────────────────────
# The core API base. Bridge POSTs to {UPSTREAM_API_URL}/intake/whatsapp.
UPSTREAM_API_URL=http://localhost:8000
# This bridge's own public base URL — used to build attachment_url that the core downloads.
BRIDGE_PUBLIC_URL=http://localhost:8088

# ── Server / storage ───────────────────────────────────────────────────────
PORT=8088
NODE_ENV=development
STAGING_DIR=./staging
MAX_MEDIA_BYTES=26214400

# ── Operational (for `bun run ops …` to connect a real number) ─────────────
WHATSAPP_WABA_ID=
WHATSAPP_REGISTER_PIN=

# Shared secret guarding the optional /internal/notify endpoint.
INTERNAL_SECRET=tia-internal-dev
